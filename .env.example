# Resend (https://resend.com) — used by app/api/contact/route.ts to email quote requests.
# Without this set, submissions are logged to the server console instead of emailed.
RESEND_API_KEY=

# Inbox(es) that should receive quote requests. Comma-separated for multiple
# recipients. Defaults to siteConfig.email if unset.
CONTACT_TO_EMAIL=hosorio@industriastexano.com,josorio@industriastexano.com,hosorio@gmail.com
